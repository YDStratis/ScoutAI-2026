# Scout.AI environment template. Copy to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Gemini (Google AI Studio API key) for the ADK coach agent.
GOOGLE_API_KEY=

# MongoDB Atlas connection string (no angle brackets around the password).
MONGODB_URI=

# Database that the BALLDONTLIE importer populated and the agent reads.
# The agent resolves: SCOUT_DB_NAME -> DB_NAME -> "scoutai".
SCOUT_DB_NAME=scoutai

# Gemini model id.
GEMINI_MODEL=gemini-2.0-flash

# Optional read-only MongoDB MCP toolset (needs Node/npx). Default off.
ENABLE_MONGODB_MCP=false

# Only needed to (re)run the BALLDONTLIE importer 07_fetch_balldontlie_no_matches.py
BALLDONTLIE_API_KEY=
